# MongoDB Atlas Connection String (Required for Vercel Backend)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/farm-to-table?retryWrites=true&w=majority

# Cloudinary Configuration
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

# AI API Key (OpenRouter or Google Gemini)
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key
GEMINI_API_KEY=your_gemini_api_key_or_openrouter_key


